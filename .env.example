# .env — Variables de entorno del proyecto
# IMPORTANTE: Este archivo NO debe subirse a GitHub (.gitignore lo excluye)
# Copia este archivo como .env y completa tus valores reales

PORT=3000

# Configuración de PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_NAME=retail_aseo
DB_USER=postgres
DB_PASSWORD=tu_contraseña_aqui

# JWT (se usará en Módulo 8)
JWT_SECRET=clave_secreta_muy_larga_y_segura_cambiar_en_produccion
JWT_EXPIRES_IN=24h

NODE_ENV=development
